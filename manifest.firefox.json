{
  "manifest_version": 2,
  "name": "CouponSnap - Auto Coupon Finder",
  "version": "0.2.0",
  "description": "Find deals, apply coupon codes, and save money automatically while you shop. Community-powered savings!",
  "browser_specific_settings": {
    "gecko": {
      "id": "couponsnap@zero-capital-ventures.com",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "tabs",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CouponSnap"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["*.js", "*.css", "*.png"]
}
